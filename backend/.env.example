# Django
DJANGO_SETTINGS_MODULE=rosa_menta.settings.development
SECRET_KEY=replace-me
JWT_SIGNING_KEY=replace-me-jwt
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://example.com

# Database (Railway provee DATABASE_URL en prod)
DATABASE_URL=postgres://user:pass@localhost:5432/rosa_menta
DB_NAME=rosa_menta
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Cloudinary (SDK directo, no storage backend)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=rosa-y-menta

# Brevo (email transaccional)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=hola@rosaymenta.mx
BREVO_SENDER_NAME=Rosa y Menta

# MercadoPago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Sentry
SENTRY_DSN=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend
FRONTEND_URL=http://localhost:3000
